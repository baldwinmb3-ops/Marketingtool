HOST=0.0.0.0
PORT=4173
APP_API_BASE_URL=http://localhost:8787
API_HOST=0.0.0.0
API_PORT=8787
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/marketingtool
# Optional PG* vars if DATABASE_URL is omitted:
# PGHOST=127.0.0.1
# PGPORT=5432
# PGUSER=postgres
# PGPASSWORD=postgres
# PGDATABASE=marketingtool
# Comma-separated allowlist. Wildcards like https://marketingtool-mocha-*.vercel.app are supported.
APP_CORS_ORIGIN=http://localhost:4173,http://127.0.0.1:4173,https://marketingtool-mocha.vercel.app,https://marketingtool-mocha-*.vercel.app
APP_SESSION_SECRET=change-me-local
APP_COOKIE_SECURE=false
# Cookie policy for session cookie: lax | strict | none
# Use `none` for cross-site frontend/backend domains (requires HTTPS).
APP_COOKIE_SAME_SITE=lax
# Optional reverse proxy trust (example: 1, true, or "loopback")
APP_TRUST_PROXY=
APP_DB_SSL=false
APP_SESSION_TTL_MS=43200000
TEST_API_BASE_URL=http://127.0.0.1:8787

# Optional runtime config for html:serve and Docker self-hosting
APP_REMOTE_URL=
APP_REMOTE_READ_KEY=
APP_REMOTE_STATE_TABLE=pricing_catalog_state
APP_REMOTE_SYNC_FUNCTION=dynamic-processor

# Optional full endpoint override for future non-Supabase backend
# Example: https://api.company.com/cloud-sync
APP_REMOTE_SYNC_ENDPOINT=
